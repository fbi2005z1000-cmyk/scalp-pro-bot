REST_CLOSED_SYNC_MIN_GAP_MS=12000
MULTI_SCANNER_ENABLED=true
MULTI_SCANNER_LOOP_MS=12000
MULTI_SCANNER_BATCH_SIZE=2
MULTI_SCANNER_CANDLE_LIMIT=260
MULTI_SCANNER_BOOTSTRAP_BATCH_SIZE=2
MULTI_SCANNER_BOOTSTRAP_DELAY_MS=220

# Bot Mode
BOT_MODE=SIGNAL_ONLY
ALLOW_AUTO=false

# Candle
