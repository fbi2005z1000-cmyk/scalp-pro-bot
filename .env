APP_NAME=Scalp Pro Bot
PORT=3000
NODE_ENV=development

# Binance
BINANCE_USE_TESTNET=false
BINANCE_REST_BASE_URL=https://fapi.binance.com
BINANCE_WS_BASE_URL=wss://fstream.binance.com/stream
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_RECV_WINDOW=5000
